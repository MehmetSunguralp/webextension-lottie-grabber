{
	"__chrome|opera__manifest_version": 3,
	"__firefox__manifest_version": 2,
	"name": "Lottie Grabber",
	"version": "0.0.0",
	"icons": {
		"16": "assets/icons/favicon-16.png",
		"32": "assets/icons/favicon-32.png",
		"48": "assets/icons/favicon-48.png",
		"128": "assets/icons/favicon-128.png"
	},
	"description": "Discover and download Lottie files used on a page",
	"homepage_url": "https://github.com/jawish/webextension-lottie-grabber",
	"short_name": "Lottie Grabber",
	"permissions": ["tabs", "storage", "webRequest", "webNavigation"],
	"__firefox__permissions": ["tabs", "storage", "webRequest", "webNavigation", "http://*/*", "https://*/*"],
	"__chrome|opera__host_permissions": ["http://*/*", "https://*/*"],
	"__chrome|opera__content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"__firefox__content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
	"__firefox__developer": {
		"name": "Jawish Hameed",
		"url": "https://github.com/jawish/webextension-lottie-grabber"
	},
	"__opera__developer": {
		"name": "Jawish Hameed"
	},
	"__chrome__minimum_chrome_version": "49",
	"__opera__minimum_opera_version": "36",
	"__chrome|opera__action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "assets/icons/favicon-16.png",
			"32": "assets/icons/favicon-32.png",
			"48": "assets/icons/favicon-48.png",
			"128": "assets/icons/favicon-128.png"
		},
		"default_title": "Lottie Grabber",
		"chrome_style": false
	},
	"__firefox__browser_action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "assets/icons/favicon-16.png",
			"32": "assets/icons/favicon-32.png",
			"48": "assets/icons/favicon-48.png",
			"128": "assets/icons/favicon-128.png"
		},
		"default_title": "Lottie Grabber",
		"browser_style": false
	},
	"__chrome|opera__background": {
		"service_worker": "js/background.bundle.js"
	},
	"__firefox__background": {
		"scripts": ["js/background.bundle.js"],
		"persistent": true
	}
}
